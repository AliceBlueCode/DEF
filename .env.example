# DEF(kari) 環境設定
# このファイルを .env にコピーして、自分の環境に合わせて編集してください。
# cp .env.example .env

# --- LLMバックエンド (text-generation-webui) ---
TEXTGEN_WEBUI_DIR=
# 例: E:\tools\text-generation-webui-main

# --- 音声合成 (VOICEVOX) ---
VOICEVOX_DIR=
VOICEVOX_URL=http://127.0.0.1:50021
# 例: E:\tools\VOICEVOX

# --- 音声合成 (Irodori TTS) ---
IRODORI_TTS_DIR=
IRODORI_TTS_URL=http://127.0.0.1:8088
# 例: E:\tools\Irodori-TTS-Server

# --- 音声合成 (Kokoro TTS) ---
KOKORO_TTS_DIR=
KOKORO_TTS_URL=http://127.0.0.1:8766
# 例: E:\tools\Kokoro-TTS

# --- 画像生成 (Stable Diffusion WebUI / A1111) ---
A1111_DIR=
A1111_URL=http://localhost:7860
# 例: E:\tools\stable-diffusion-webui

# --- 画像生成 (ComfyUI) ---
COMFYUI_DIR=
COMFYUI_URL=http://127.0.0.1:8188
# 例: E:\tools\ComfyUI_windows_portable

# --- デフォルトモデル設定（省略時はコード内フォールバック値を使用）---

# LLM
OLLAMA_DEFAULT_MODEL=huihui_ai/qwen2.5-abliterate:7b

# T2I
HF_DEFAULT_MODEL=black-forest-labs/FLUX.1-schnell
CIVITAI_DEFAULT_MODEL_AIR=
# Civitaiモデルページ → 「Use this model」→「API」タブ → AIR欄からコピー
# 例: urn:air:sdxl:checkpoint:civitai:101055@128078
# ※ Civitaiは公式デフォルトモデルが存在しないため、使用するモデルを必ず設定してください
# ※ 未設定のままCivitaiバックエンドで生成しようとするとエラーになります

# TTS デフォルト話者
VOICEVOX_DEFAULT_SPEAKER=2
IRODORI_DEFAULT_SPEAKER=sample
GEMINI_TTS_DEFAULT_VOICE=Kore
KOKORO_DEFAULT_VOICE=jf_alpha

# --- APIキー（任意）---
# 設定タブの「APIキー管理」から登録すると暗号化保存されます（推奨）。
# 起動スクリプトやCI環境など、UIを使わずに設定したい場合は以下に直接記入してください。
# 環境変数は secrets_store より優先されます。
#
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPL_API_KEY=           # 無料プランのキーは末尾が :fx
# CIVITAI_API_TOKEN=
# HF_TOKEN=

# --- 開発者向けオプション ---
# DEF_DEBUG_ENDPOINTS=true
# 有効にすると /api/chat/force-rating エンドポイントが使用可能になります（本番運用では無効推奨）
# DEF_MAX_SESSIONS=1000
# インメモリに保持するセッション数の上限（超過時は古いものから破棄）

# --- 各バックエンドのディレクトリが未設定の場合、自動起動はスキップされます ---
# --- APIキーは設定タブのAPIキー管理から設定してください（暗号化保存されます） ---
